<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="CBIT RMM Agent"
           Manufacturer="CBIT Inc."
           Version="1.0.0"
           UpgradeCode="7A2E4F3B-8D1C-4E5A-B6F9-0C3D2E1A5B8F"
           Scope="perMachine"
           InstallerVersion="500">

    <MajorUpgrade DowngradeErrorMessage="A newer version of CBIT RMM Agent is already installed." />
    <Launch Condition="NOT Installed OR REMOVE" Message="CBIT RMM Agent is already installed. Uninstall the current version first, or install a newer version." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="CBITFOLDER" Name="CBIT">
        <Directory Id="INSTALLFOLDER" Name="Agent">
          <Directory Id="LOGSFOLDER" Name="logs" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Add/Remove Programs branding -->
    <Icon Id="AxisIcon.ico" SourceFile="favicon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AxisIcon.ico" />
    <Property Id="ARPHELPLINK" Value="https://axis.gocbit.com" />

    <!-- Customer key property — server patches this value in the MSI Property table
         before download using Windows Installer COM API (no binary scanning needed).
         Default "CBIT_YOURKEY" is the placeholder; agent ignores it at startup. -->
    <Property Id="CUSTOMER_KEY" Value="CBIT_YOURKEY" Secure="yes" />

    <Feature Id="MainFeature" Title="CBIT RMM Agent" Level="1">
      <ComponentRef Id="CbitAgentExe" />
      <ComponentRef Id="CbitTrayExe" />
      <ComponentRef Id="CustomerKeyReg" />
      <ComponentRef Id="LogsFolder" />
      <ComponentRef Id="CleanupOnUninstall" />
    </Feature>

    <!-- Grant SeSecurityPrivilege to LocalSystem (S-1-5-18) so the agent can read the Security event log.
         Script installed alongside agent; runs via deferred custom action as elevated SYSTEM.
         Return="ignore" so install succeeds even if this fails (agent has graceful fallback). -->
    <CustomAction Id="GrantSecurityPrivilege"
                  Directory="INSTALLFOLDER"
                  ExeCommand="powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]grant-secpriv.ps1&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Launch tray app as the logged-in user after install/upgrade -->
    <CustomAction Id="LaunchTray"
                  FileRef="CbitTrayExeFile"
                  ExeCommand=""
                  Impersonate="yes"
                  Return="asyncNoWait" />

    <!-- Kill processes and stop service early during uninstall to prevent "files in use" prompt -->
    <CustomAction Id="StopAgentService"
                  Directory="INSTALLFOLDER"
                  ExeCommand="sc.exe stop CbitRmmAgent"
                  Execute="immediate"
                  Return="ignore" />

    <CustomAction Id="KillTrayProcess"
                  Directory="INSTALLFOLDER"
                  ExeCommand="taskkill.exe /f /im CbitAgent.Tray.exe"
                  Execute="immediate"
                  Return="ignore" />

    <CustomAction Id="KillAgentProcess"
                  Directory="INSTALLFOLDER"
                  ExeCommand="taskkill.exe /f /im CbitAgent.exe"
                  Execute="immediate"
                  Return="ignore" />

    <CustomAction Id="DeleteAgentService"
                  Directory="INSTALLFOLDER"
                  ExeCommand="sc.exe delete CbitRmmAgent"
                  Execute="immediate"
                  Return="ignore" />

    <InstallExecuteSequence>
      <!-- On uninstall: stop service → kill processes → delete service, all before InstallValidate -->
      <Custom Action="StopAgentService" Before="KillTrayProcess" Condition="REMOVE" />
      <Custom Action="KillTrayProcess" Before="KillAgentProcess" Condition="REMOVE" />
      <Custom Action="KillAgentProcess" Before="DeleteAgentService" Condition="REMOVE" />
      <Custom Action="DeleteAgentService" Before="InstallValidate" Condition="REMOVE" />
      <!-- On install/upgrade: grant Security log privilege, then launch tray app -->
      <Custom Action="GrantSecurityPrivilege" Before="InstallFinalize" Condition="NOT REMOVE" />
      <Custom Action="LaunchTray" After="InstallFinalize" Condition="NOT REMOVE" />
    </InstallExecuteSequence>

  </Package>
</Wix>
