<Project Sdk="WixToolset.Sdk/6.0.2">

  <PropertyGroup>
    <OutputType>Package</OutputType>
    <InstallerPlatform>x64</InstallerPlatform>
    <AgentPublishDir>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\publish'))</AgentPublishDir>
    <TrayPublishDir>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\publish-tray'))</TrayPublishDir>
  </PropertyGroup>

  <PropertyGroup>
    <DefineConstants>PublishDir=$(AgentPublishDir);PublishTrayDir=$(TrayPublishDir)</DefineConstants>
  </PropertyGroup>

</Project>
